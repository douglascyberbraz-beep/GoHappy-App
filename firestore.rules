rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    // HELPERS
    // ═══════════════════════════════════════════════════════════════

    // Usuario autenticado (no anónimo)
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    // Usuario autenticado real (no invitado anónimo)
    function isRealUser() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Es el propio usuario
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Miembro de la familia
    function isFamilyMember(familyId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/families/$(familyId)) &&
             request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.miembros;
    }

    // Tamaño de string dentro de límites
    function validString(field, min, max) {
      return field is string && field.size() >= min && field.size() <= max;
    }

    // Timestamp no es futuro (±5 min de tolerancia)
    function validTimestamp(ts) {
      return ts == request.time || (ts >= request.time - duration.value(300, 's'));
    }

    // Solo campos permitidos fueron tocados
    function onlyFields(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // Ningún campo de los bloqueados fue tocado
    function noFields(blocked) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(blocked);
    }


    // ═══════════════════════════════════════════════════════════════
    // USUARIOS
    // ═══════════════════════════════════════════════════════════════
    match /users/{uid} {

      // Leer perfil: el propio usuario, o cualquier autenticado (para ranking)
      allow get:  if isAuthenticated();
      allow list: if isAuthenticated();

      // Crear perfil: solo el propio usuario, campos obligatorios validados
      allow create: if isOwner(uid)
        && validString(request.resource.data.nickname, 2, 24)
        && validString(request.resource.data.email, 3, 254)
        && request.resource.data.points    is number && request.resource.data.points    >= 0
        && request.resource.data.familyId  == null
        && request.resource.data.createdAt == request.time;

      // Actualizar: solo el propio usuario y solo campos no protegidos
      allow update: if isOwner(uid)
        && noFields(['uid', 'email', 'createdAt', 'referralCode', 'referredBy'])
        && noFields(['points', 'weeklyPoints', 'familyId', 'rol'])  // Solo Cloud Functions
        && (!request.resource.data.keys().hasAny(['nickname']) ||
            validString(request.resource.data.nickname, 2, 24))
        && (!request.resource.data.keys().hasAny(['photo']) ||
            request.resource.data.photo is string && request.resource.data.photo.size() <= 10);

      // Borrar: nunca (soft delete solo via Cloud Functions)
      allow delete: if false;
    }

    // Acumulación de puntos solo via Cloud Functions (admin SDK)
    // Los clientes NO pueden tocar /users/{uid}/points directamente


    // ═══════════════════════════════════════════════════════════════
    // FAMILIAS
    // ═══════════════════════════════════════════════════════════════
    match /families/{familyId} {

      // Leer: solo miembros de la familia
      allow get:  if isAuthenticated() && request.auth.uid in resource.data.miembros;
      allow list: if false; // Nunca listar todas las familias

      // Crear: real user, máx 1 miembro inicial (el creador)
      allow create: if isRealUser()
        && request.auth.uid == request.resource.data.creadoPor
        && request.resource.data.miembros.size() == 1
        && request.resource.data.miembros[0] == request.auth.uid
        && validString(request.resource.data.nombre, 2, 40);

      // Actualizar: solo miembros, máx 6 miembros, solo campos permitidos
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.miembros
        && request.resource.data.miembros.size() <= 6
        && request.resource.data.creadoPor == resource.data.creadoPor  // No cambiar creador
        && noFields(['creadoPor', 'createdAt']);

      // Borrar: solo el creador
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.creadoPor;
    }


    // ═══════════════════════════════════════════════════════════════
    // QUESTS (Catálogo compartido + progreso por familia)
    // ═══════════════════════════════════════════════════════════════
    match /quests/{questId} {

      // Leer: cualquier usuario autenticado
      allow get:  if isAuthenticated();
      allow list: if isAuthenticated();

      // Crear: solo usuarios reales, con campos validados
      allow create: if isRealUser()
        && validString(request.resource.data.title, 3, 120)
        && request.resource.data.points is number
        && request.resource.data.points >= 0
        && request.resource.data.points <= 1000;

      // Actualizar: solo el usuario o miembro de la familia propietaria,
      // y solo campos de progreso (no título, puntos, etc.)
      allow update: if isAuthenticated()
        && (request.auth.uid == resource.data.userId ||
            (resource.data.familyId != null && isFamilyMember(resource.data.familyId)))
        && onlyFields(['status', 'progress', 'completedAt', 'currentStep',
                       'updatedAt', 'lastUpdatedBy']);

      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════
    // COMPLETADAS (Historial de quests terminadas por familia)
    // ═══════════════════════════════════════════════════════════════
    match /completadas/{familyId} {

      // Leer: solo miembros de la familia
      allow read: if isAuthenticated() && isFamilyMember(familyId);

      // Subcolección de registros
      match /registros/{registroId} {
        allow read:   if isAuthenticated() && isFamilyMember(familyId);
        allow create: if isAuthenticated() && isFamilyMember(familyId)
          && request.auth.uid == request.resource.data.userId;
        allow update, delete: if false;
      }
    }


    // ═══════════════════════════════════════════════════════════════
    // ACTIVITY (Memories — historial de actividades del usuario)
    // ═══════════════════════════════════════════════════════════════
    match /activity/{actId} {

      // Leer: solo el propio usuario
      allow get:  if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow list: if isAuthenticated(); // Restringido por query (userId == uid)

      // Crear: solo el propio usuario
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId
        && validString(request.resource.data.title, 1, 120);

      allow update, delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════
    // ALERTAS DE SEGURIDAD (Safe)
    // ═══════════════════════════════════════════════════════════════
    match /alerts/{alertId} {

      // Leer: cualquier usuario autenticado
      allow get:  if isAuthenticated();
      allow list: if isAuthenticated();

      // Crear: usuario real, campos validados, no puede auto-asignar votos
      allow create: if isRealUser()
        && request.auth.uid == request.resource.data.userId
        && validString(request.resource.data.title, 3, 100)
        && validString(request.resource.data.description, 5, 500)
        && request.resource.data.votes == 0
        && request.resource.data.active == true;

      // Actualizar: creador puede archivar | cualquiera puede votar
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.userId && onlyFields(['active', 'updatedAt'])) ||
        (onlyFields(['votes']) && request.resource.data.votes == resource.data.votes + 1)
      );

      // Borrar: solo el creador
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }


    // ═══════════════════════════════════════════════════════════════
    // POSTS DE TRIBU
    // ═══════════════════════════════════════════════════════════════
    match /posts/{postId} {

      // Leer: cualquier usuario autenticado
      allow get:  if isAuthenticated();
      allow list: if isAuthenticated();

      // Crear: usuario real, contenido validado, sin HTML
      allow create: if isRealUser()
        && request.auth.uid == request.resource.data.userId
        && validString(request.resource.data.content, 1, 160)
        && request.resource.data.likes == 0;

      // Actualizar: autor puede editar contenido | cualquiera puede dar like
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.userId && onlyFields(['content', 'updatedAt']) &&
         validString(request.resource.data.content, 1, 160)) ||
        (onlyFields(['likes']) && request.resource.data.likes == resource.data.likes + 1)
      );

      // Borrar: solo el autor
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }


    // ═══════════════════════════════════════════════════════════════
    // RESEÑAS (Mapa)
    // ═══════════════════════════════════════════════════════════════
    match /reviews/{reviewId} {
      allow get:  if isAuthenticated();
      allow list: if isAuthenticated();

      allow create: if isRealUser()
        && request.auth.uid == request.resource.data.userId
        && validString(request.resource.data.comment, 1, 300)
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;

      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId
        && onlyFields(['comment', 'rating', 'updatedAt'])
        && validString(request.resource.data.comment, 1, 300);

      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }


    // ═══════════════════════════════════════════════════════════════
    // INVITACIONES / REFERIDOS
    // ═══════════════════════════════════════════════════════════════
    match /invitations/{code} {

      // Validar código: cualquier autenticado puede leer
      allow get:  if isAuthenticated();
      allow list: if false;

      // Crear invitación: solo usuario real, código validado
      allow create: if isRealUser()
        && request.auth.uid == request.resource.data.createdBy
        && request.resource.data.used == false
        && validString(request.resource.data.code, 4, 20);

      // Marcar como usada: solo el sistema (via Cloud Functions)
      allow update: if false;
      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════
    // LOCATIONS (Solo lectura — generado por AI/admin)
    // ═══════════════════════════════════════════════════════════════
    match /locations/{locId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // NEWS, EVENTS (Solo lectura pública)
    match /news/{docId}   { allow read: if isAuthenticated(); allow write: if false; }
    match /events/{docId} { allow read: if isAuthenticated(); allow write: if false; }


    // ═══════════════════════════════════════════════════════════════
    // COLECCIONES INTERNAS (solo Cloud Functions con admin SDK)
    // ═══════════════════════════════════════════════════════════════
    match /_ratelimits/{uid}  { allow read, write: if false; }
    match /_ailogs/{docId}    { allow read, write: if false; }
    match /_referrals/{docId} { allow read, write: if false; }


    // ═══════════════════════════════════════════════════════════════
    // DENY ALL — Bloque final de seguridad
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
