rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    // HELPERS
    // ═══════════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isRealUser() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isFamilyMember(familyId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/families/$(familyId)) &&
             request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.miembros;
    }

    function validString(field, min, max) {
      return field is string && field.size() >= min && field.size() <= max;
    }

    function onlyFields(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    function noFields(blocked) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(blocked);
    }


    // ═══════════════════════════════════════════════════════════════
    // USUARIOS
    // ═══════════════════════════════════════════════════════════════
    match /users/{uid} {

      allow get:  if isAuthenticated();
      allow list: if isAuthenticated();

      // CREAR perfil: solo el propio usuario, campos validados
      allow create: if isOwner(uid)
        && validString(request.resource.data.nickname, 2, 24)
        && (request.resource.data.email is string)
        && request.resource.data.points    is number && request.resource.data.points    >= 0
        && (!request.resource.data.keys().hasAny(['familyId']) || request.resource.data.familyId == null)
        && request.resource.data.createdAt == request.time;

      // ACTUALIZAR perfil: solo el propio usuario
      // Campos siempre bloqueados: identidad e historia
      // familyId/rol: SE PUEDE actualizar (para crear/unirse/salir de familia)
      allow update: if isOwner(uid)
        && noFields(['uid', 'email', 'createdAt', 'referralCode', 'referredBy'])
        // Validación nickname si se modifica
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['nickname']) ||
            validString(request.resource.data.nickname, 2, 24))
        // Validación photo si se modifica (emoji o URL corta)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['photo']) ||
            request.resource.data.photo is string && request.resource.data.photo.size() <= 500)
        // familyId: null o string corto
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['familyId']) ||
            request.resource.data.familyId == null ||
            (request.resource.data.familyId is string && request.resource.data.familyId.size() <= 40))
        // rol: null, 'admin' o 'miembro'
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['rol']) ||
            request.resource.data.rol == null ||
            request.resource.data.rol in ['admin', 'miembro'])
        // Points: solo aumentar, máximo 999999
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['points']) ||
            (request.resource.data.points is number
             && request.resource.data.points >= resource.data.points
             && request.resource.data.points <= 999999))
        // weeklyPoints: número 0-999999 (puede resetear semanalmente)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['weeklyPoints']) ||
            (request.resource.data.weeklyPoints is number
             && request.resource.data.weeklyPoints >= 0
             && request.resource.data.weeklyPoints <= 999999));

      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════
    // FAMILIAS
    // ═══════════════════════════════════════════════════════════════
    match /families/{familyId} {

      allow get:  if isAuthenticated() && request.auth.uid in resource.data.miembros;

      // LIST: necesario para buscar por codigoInvitacion
      // (limitamos lecturas individuales con el get de arriba)
      allow list: if isAuthenticated();

      allow create: if isRealUser()
        && request.auth.uid == request.resource.data.creadoPor
        && request.resource.data.miembros.size() == 1
        && request.resource.data.miembros[0] == request.auth.uid
        && validString(request.resource.data.nombre, 2, 40)
        && validString(request.resource.data.codigoInvitacion, 4, 10);

      // UPDATE: cualquier miembro puede modificar; máximo 6 miembros
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.miembros
        && request.resource.data.miembros.size() <= 6
        && request.resource.data.miembros.size() >= 0
        && request.resource.data.creadoPor == resource.data.creadoPor
        && noFields(['creadoPor', 'fechaCreacion', 'codigoInvitacion']);

      // DELETE: solo el creador
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.creadoPor;
    }


    // ═══════════════════════════════════════════════════════════════
    // QUESTS (Catálogo por familia)
    // ═══════════════════════════════════════════════════════════════
    match /quests/{questId} {

      allow get:  if isAuthenticated();
      allow list: if isAuthenticated();

      // CREAR: usuario real, dentro de una familia (bootstrap)
      allow create: if isRealUser()
        && validString(request.resource.data.titulo, 3, 120)
        && request.resource.data.puntos is number
        && request.resource.data.puntos >= 0
        && request.resource.data.puntos <= 1000;

      // UPDATE: solo el creador o miembro de la familia, solo campos progreso
      allow update: if isAuthenticated()
        && (resource.data.familyId == null ||
            isFamilyMember(resource.data.familyId))
        && onlyFields(['activa', 'completadaHoy', 'updatedAt']);

      allow delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════
    // COMPLETADAS — historial de quests por familia
    // ═══════════════════════════════════════════════════════════════
    match /completadas/{familyId} {
      allow read: if isAuthenticated() && isFamilyMember(familyId);

      match /registros/{registroId} {
        allow read:   if isAuthenticated() && isFamilyMember(familyId);

        // CREATE: miembro de la familia, su uid en campo userId
        allow create: if isAuthenticated() && isFamilyMember(familyId)
          && request.auth.uid == request.resource.data.userId
          && request.resource.data.questId is string
          && request.resource.data.fecha is string
          && request.resource.data.puntosGanados is number
          && request.resource.data.puntosGanados >= 0
          && request.resource.data.puntosGanados <= 1000;

        allow update, delete: if false;
      }
    }


    // ═══════════════════════════════════════════════════════════════
    // ACTIVITY — historial personal (memorias)
    // ═══════════════════════════════════════════════════════════════
    match /activity/{actId} {

      allow get:  if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow list: if isAuthenticated();

      // CREATE: el propio usuario, type obligatorio, title opcional
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.type is string
        && (!request.resource.data.keys().hasAny(['title']) ||
            validString(request.resource.data.title, 1, 200));

      allow update, delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════
    // ALERTAS DE SEGURIDAD
    // ═══════════════════════════════════════════════════════════════
    match /alerts/{alertId} {

      allow get:  if isAuthenticated();
      allow list: if isAuthenticated();

      allow create: if isRealUser()
        && request.auth.uid == request.resource.data.userId
        && validString(request.resource.data.title, 3, 100)
        && validString(request.resource.data.description, 5, 500)
        && request.resource.data.votes == 0
        && request.resource.data.active == true;

      // UPDATE: el creador puede archivar | cualquiera puede sumar 1 voto
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.userId && onlyFields(['active', 'updatedAt'])) ||
        (onlyFields(['votes']) && request.resource.data.votes == resource.data.votes + 1)
      );

      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }


    // ═══════════════════════════════════════════════════════════════
    // POSTS DE TRIBU
    // ═══════════════════════════════════════════════════════════════
    match /posts/{postId} {

      allow get:  if isAuthenticated();
      allow list: if isAuthenticated();

      allow create: if isRealUser()
        && request.auth.uid == request.resource.data.userId
        && validString(request.resource.data.content, 1, 280)
        && request.resource.data.likes == 0;

      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.userId && onlyFields(['content', 'updatedAt']) &&
         validString(request.resource.data.content, 1, 280)) ||
        (onlyFields(['likes']) && request.resource.data.likes == resource.data.likes + 1)
      );

      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }


    // ═══════════════════════════════════════════════════════════════
    // RESEÑAS (Mapa)
    // ═══════════════════════════════════════════════════════════════
    match /reviews/{reviewId} {
      allow get:  if isAuthenticated();
      allow list: if isAuthenticated();

      allow create: if isRealUser()
        && request.auth.uid == request.resource.data.userId
        && validString(request.resource.data.siteName, 1, 120)
        && (request.resource.data.comment == '' || validString(request.resource.data.comment, 1, 500))
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;

      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId
        && onlyFields(['comment', 'rating', 'updatedAt'])
        && validString(request.resource.data.comment, 1, 500);

      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }


    // ═══════════════════════════════════════════════════════════════
    // INVITACIONES / REFERIDOS (legacy, opcional)
    // ═══════════════════════════════════════════════════════════════
    match /invitations/{code} {
      allow get:  if isAuthenticated();
      allow list: if isAuthenticated();
      allow create: if isRealUser()
        && request.auth.uid == request.resource.data.createdBy
        && request.resource.data.used == false
        && validString(request.resource.data.code, 4, 20);
      allow update, delete: if false;
    }


    // ═══════════════════════════════════════════════════════════════
    // CONTENIDO PÚBLICO (read-only)
    // ═══════════════════════════════════════════════════════════════
    match /locations/{locId} { allow read: if isAuthenticated(); allow write: if false; }
    match /news/{docId}      { allow read: if isAuthenticated(); allow write: if false; }
    match /events/{docId}    { allow read: if isAuthenticated(); allow write: if false; }


    // ═══════════════════════════════════════════════════════════════
    // INTERNAS (solo Cloud Functions con admin SDK)
    // ═══════════════════════════════════════════════════════════════
    match /_ratelimits/{uid}  { allow read, write: if false; }
    match /_ailogs/{docId}    { allow read, write: if false; }
    match /_referrals/{docId} { allow read, write: if false; }
    match /_aicache/{docId}   { allow read, write: if false; }


    // ═══════════════════════════════════════════════════════════════
    // DENY ALL — bloque final de seguridad
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
