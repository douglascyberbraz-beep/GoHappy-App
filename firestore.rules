rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════════
    // MODO BETA — TODO ABIERTO PARA USUARIOS AUTENTICADOS
    // (cualquier user logueado puede leer/escribir cualquier doc)
    //
    // ⚠ Restablecer reglas de producción ANTES de release oficial.
    // Las reglas estrictas están en backups/firestore.rules.strict (commit history).
    // ════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Internas — solo admin SDK
    match /_audit/{docId}     { allow read, write: if false; }
    match /_ailogs/{docId}    { allow read, write: if false; }
    match /_aicache/{docId}   { allow read, write: if false; }
    match /_ratelimits/{uid}  { allow read, write: if false; }
    match /_referrals/{docId} { allow read, write: if false; }
    match /_security/{docId}  { allow read, write: if false; }
  }
}
