{
  "name": "gohappy-app",
  "version": "3.0.0-beta",
  "description": "GoHappy Family App - La comunidad real para familias modernas",
  "main": "index.html",
  "scripts": {
    "build": "echo 'No build step needed for Vanilla JS'",
    "sync": "npx cap sync",
    "sync:android": "npx cap sync android",
    "sync:ios": "npx cap sync ios",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "run:android": "npx cap run android",
    "run:ios": "npx cap run ios",
    "serve": "node server.js",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:all": "firebase deploy --only hosting,firestore:rules,firestore:indexes",
    "build:www": "node scripts/build-www.js",
    "beta:android": "node scripts/build-www.js && npx cap sync android && npx cap open android",
    "beta:ios": "node scripts/build-www.js && npx cap sync ios && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^5.0.0",
    "@capacitor/cli": "^5.0.0",
    "@capacitor/android": "^5.0.0",
    "@capacitor/ios": "^5.0.0",
    "@capacitor/haptics": "^5.0.0",
    "@capacitor/keyboard": "^5.0.0",
    "@capacitor/local-notifications": "^5.0.0",
    "@capacitor/push-notifications": "^5.0.0",
    "@capacitor/splash-screen": "^5.0.0",
    "@capacitor/status-bar": "^5.0.0",
    "@capacitor/geolocation": "^5.0.0"
  }
}
